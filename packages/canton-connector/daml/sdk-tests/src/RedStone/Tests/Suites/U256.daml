module RedStone.Tests.Suites.U256
(
    runTests
)
where

import RedStone.Tests.Test
import RedStone.Tests.Run
import RedStone.Tests.Helpers
import RedStone.U256
import DA.List as L (sort)

runTests : (Action m, ActionFail m, CanAbort m) => m ()
runTests = do
  runSuites testSuites
  runSuites testSuitesComp
  runSuites testSuitesSort

testSuites = [
    TestSuite with cases = testBasicOperations, name = "U256 Basic Operation Tests", test = runTest
    , TestSuite with cases = testLargeNumbers, name = "U256 Basic Operation for Large Numbers Tests", test = runTest
    , TestSuite with cases = testEdgeCases, name = "U256 Edge Case Tests", test = runTest
    ]

testSuitesComp = [
    TestSuite with cases = testComparison, name = "U256 Comparison Tests", test = runTest
    ]

testSuitesSort = [
    TestSuite with cases = testSort, name = "U256 Sorting", test = runTest
    ]

testBasicOperations =
    [ TestCase with
        name = "10 / 2 = 5"
        input = Input with input = n 10, op = divBy2
        output = n 5
    , TestCase with
        name = "5 + 5 = 10"
        input = Input with input = n 5, op = \x -> add x x
        output = n 10
    , TestCase with
        name = "10 mod 2 = 0"
        input = Input with input = n 10, op = mod2
        output = n 0
    , TestCase with
        name = "5 mod 2 = 1"
        input = Input with input = n 5, op = mod2
        output = n 1
    , TestCase with
        name = "255 / 2 = 127"
        input = Input with input = u256FromBeByteList [255], op = divBy2
        output = u256FromBeByteList [127]
    ]

testLargeNumbers =
    [ TestCase with
        name = "65536 / 2 = 32768"
        input = Input with input = u256FromBeByteList [1, 0, 0], op = divBy2
        output = u256FromBeByteList [128, 0]
    , TestCase with
        name = "2^24 / 2 = 2^23"
        input = Input with input = u256FromBeByteList [1, 0, 0, 0], op = divBy2
        output = u256FromBeByteList [128, 0, 0]
    , TestCase with
        name = "max32bit / 2 = 2147483647"
        input = Input with input = u256FromBeByteList [255, 255, 255, 255], op = divBy2
        output = u256FromBeByteList [127, 255, 255, 255]
    , TestCase with
        name = "large 128-bit / 2 "
        input = Input with input = u256FromBeByteList $ replicate 16 255, op = divBy2
        output = u256FromBeByteList $ 127 :: replicate 15 255
    , TestCase with
        name = "(max-1) / 2 "
        input = Input with input = u256FromBeByteList $ replicate 31 255 ++ [254], op = divBy2
        output = u256FromBeByteList $ 127 :: replicate 31 255
    ]

testEdgeCases =
  -- Test: Zero
    [ TestCase with
        name = "0 / 2 = 0"
        input = Input with input = n 0, op = divBy2
        output = n 0
    , TestCase with
        name = "0 + 0 = 0"
        input = Input with input = n 0, op = \x -> add x x
        output = n 0
    , TestCase with
        name = "0 mod 2 = 0"
        input = Input with input = n 0, op = mod2
        output = n 0

  -- Test: One
    , TestCase with
        name = "1 / 2 = 0"
        input = Input with input = n 1, op = divBy2
        output = n 0
    , TestCase with
        name = "1 mod 2 = 1"
        input = Input with input = n 1, op = mod2
        output = n 1

-- Test: Max U256
    , TestCase with
        name =  "maxU256 / 2"
        input = Input with input = maxU256, op = divBy2
        output = maxDiv2
    , TestCase with
        name = "maxU256 mod 2 = 1"
        input = Input with input = maxU256, op = mod2
        output = n 1

  -- Test: Carry propagation
    , TestCase with
        name = "65535 + 1 = 65536"
        input = Input with input = u256FromBeByteList [255, 255], op = add $ n 1
        output = u256FromBeByteList [1, 0, 0]
    , TestCase with
        name = "carry through 16 bytes"
        input = Input with input = u256FromBeByteList $ replicate 16 255, op = add $ n 1
        output = u256FromBeByteList $ 1 :: replicate 16 0
    ]

testComparison =
    [ TestCase with
        name = "1 < 2"
        input = Input with input = (n 1, n 2), op = uncurry (<)
        output = True
    , TestCase with
        name = "2 > 1"
        input = Input with input = (n 2, n 1), op = uncurry (>)
        output = True
    , TestCase with
        name = "2 > 0"
        input = Input with input = (n 2, n 0), op = uncurry (>)
        output = True
    , TestCase with
        name = "1 == 1"
        input = Input with input = (n 1, n 1), op = uncurry (==)
        output = True
     , TestCase with
        name = "256 < 257"
        input = Input with input = (u256FromBeByteList [1, 0], u256FromBeByteList [1, 1]), op = uncurry (<)
        output = True
    ]

testSort =
    [ TestCase with
        name = "sort"
        input =  Input with
            input = [maxDiv2, u256FromBeByteList [1, 0], n 1, u256FromBeByteList [255], n 2, maxU256, n 0]
            op = sort
        output = [n 0, n 1, n 2, u256FromBeByteList [255], u256FromBeByteList [1, 0], maxDiv2, maxU256]
    ]
