module RedStone.Tests.Suites.Trim
(
    runTests
)
where

import RedStone.Tests.Test
import RedStone.Tests.Run
import RedStone.Internal.Trim
import RedStone.Internal.Bytes

runTests : (Action m, ActionFail m, CanAbort m) => m ()
runTests = do
  runSuites [trimZerosSuite, trimLeadingZerosSuite]
  runSuite trimStartSuite
  runSuite bytesTrimSuite
  runSuite bytesTrimNumSuite

-- TrimZeros tests

trimZerosSuite = TestSuite with
  cases = trimZerosCases
  name = "TrimTrailingZeros Tests"
  test = trimTrailingZeros

trimZerosCases =
    [ TestCase with
        name = "trim trailing zeros from redstone marker"
        input = [0, 0, 2, 237, 87, 1, 30, 0, 0]
        output = [0, 0, 2, 237, 87, 1, 30]
    , TestCase with
        name = "trim trailing zeros idempotent"
        input = [0, 0, 2, 237, 87, 1, 30]
        output = [0, 0, 2, 237, 87, 1, 30]
    , TestCase with
        name = "trim trailing zeros from empty list"
        input = ([] : [Int])
        output = []
    , TestCase with
        name = "trim trailing zeros all zeros"
        input = [0, 0, 0, 0]
        output = []
    , TestCase with
        name = "trim trailing zeros no trailing zeros"
        input = [1, 2, 3]
        output = [1, 2, 3]
    , TestCase with
        name = "trim trailing zeros single non-zero"
        input = [42]
        output = [42]
    , TestCase with
        name = "trim trailing zeros single zero"
        input = [0]
        output = []
    ]

-- TrimLeadingZeros tests

trimLeadingZerosSuite = TestSuite with
  cases = trimLeadingZerosCases
  name = "TrimLeadingZeros Tests"
  test = trimLeadingZeros

trimLeadingZerosCases =
    [ TestCase with
        name = "trim leading zeros"
        input = [0, 0, 1, 2, 3]
        output = [1, 2, 3]
    , TestCase with
        name = "trim leading zeros empty"
        input = ([] : [Int])
        output = []
    , TestCase with
        name = "trim leading zeros all zeros"
        input = [0, 0, 0]
        output = []
    , TestCase with
        name = "trim leading zeros no leading zeros"
        input = [1, 2, 0, 3]
        output = [1, 2, 0, 3]
    ]

-- TrimStart tests

trimStartSuite = TestSuite with
  cases = trimStartCases
  name = "TrimStart Tests"
  test = runTest

trimStartCases =
    [ TestCase with
        name = "trim 3 elements from start"
        input = Input with
          input = [1, 2, 3, 4, 5]
          op = trimStart 3
        output = ([4, 5], [3, 2, 1])
    , TestCase with
        name = "trim 0 elements from start"
        input = Input with
          input = [1, 2, 3]
          op = trimStart 0
        output = ([1, 2, 3], ([] : [Int]))
    , TestCase with
        name = "trim all elements"
        input = Input with
          input = [1, 2, 3]
          op = trimStart 3
        output = (([] : [Int]), [3, 2, 1])
    ]

-- BytesTrim tests

bytesTrimSuite = TestSuite with
  cases = bytesTrimCases
  name = "BytesTrim Tests"
  test = runTest

bytesTrimCases =
    [ TestCase with
        name = "bytesTrim 3 from [1,2,3,4,5]"
        input = Input with
          input = fromList [1, 2, 3, 4, 5]
          op = \bytes ->
            let (Bytes{revList=rest}, trimmed) = bytesTrim 3 bytes
            in (rest, trimmed)
        output = ([2, 1], [3, 4, 5])
    , TestCase with
        name = "bytesTrim 0 from [1,2,3]"
        input = Input with
          input = fromList [1, 2, 3]
          op = \bytes ->
            let (Bytes{revList=rest}, trimmed) = bytesTrim 0 bytes
            in (rest, trimmed)
        output = ([3, 2, 1], ([] : [Int]))
    ]

-- BytesTrimNum tests

bytesTrimNumSuite = TestSuite with
  cases = bytesTrimNumCases
  name = "BytesTrimNum Tests"
  test = runTest

bytesTrimNumCases =
    [ TestCase with
        name = "bytesTrimNum 2 from [0,1,0]"
        input = Input with
          input = fromList [0, 1, 0]
          op = \bytes ->
            let (Bytes{revList=rest}, num) = bytesTrimNum 2 bytes
            in (rest, num)
        output = ([0], 256)
    , TestCase with
        name = "bytesTrimNum 1 from [255]"
        input = Input with
          input = fromList [255]
          op = \bytes ->
            let (Bytes{revList=rest}, num) = bytesTrimNum 1 bytes
            in (rest, num)
        output = (([] : [Int]), 255)
    , TestCase with
        name = "bytesTrimNum 2 from [1,0]"
        input = Input with
          input = fromList [1, 0]
          op = \bytes ->
            let (Bytes{revList=rest}, num) = bytesTrimNum 2 bytes
            in (rest, num)
        output = (([] : [Int]), 256)
    ]
