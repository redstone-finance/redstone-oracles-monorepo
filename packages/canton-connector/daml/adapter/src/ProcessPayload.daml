module ProcessPayload
(
  processAndWritePrices
  , hasNewPrices
  , WriteContext(..)
  , Factories(..)
  , AdapterState(..)
) where

import DA.Assert
import DA.List as L
import DA.Map as M
import DA.Optional
import RedStone.Config(verifyConfigAgainstLedger)
import RedStone.Processor
import IRedStonePricePillFactory
import RedStoneTypes
import Events
import PillRecord
import Verify
import Rewards
import Config(adapter_config_fun, pill_staleness_ms)

data WriteContext = WriteContext
  with
    caller : Party
    owner : Party
    updaters : [Party]
    viewers : [Party]
  deriving (Eq, Show)

data Factories = Factories
  with
    pillFactory : Optional (ContractId IRedStonePricePillFactory)
    rewardFactory : Optional (ContractId IIRewardFactory)

data AdapterState = AdapterState
  with
    feedData : M.Map RedStoneFeedId [PillRecord]
    rewardState : Optional RewardState

-- Public

-- Note: emitErrorEvents creates PriceUpdateEvent with signatory=owner.
-- This works because hasNewPrices runs within a choice on RedStoneAdapter (signatory owner),
-- so the owner's authority is available via DAML's authority propagation rules.
hasNewPrices ctx adapterId feedData feedIds currentTime payloadHex = do
  ((newValues, _, rejectedValues), _) <- checkNewValues feedData feedIds currentTime payloadHex
  _ <- emitErrorEvents (ctx.owner, ctx.updaters) adapterId rejectedValues

  return $ not . L.null $ newValues

-- | Processes the payload, writes new price pills, and accumulates/batches reward creation.
-- Reward state tracks accumulated pill count and is flushed to the RewardFactory
-- when the configured time threshold (min_reward_creation_ms) is exceeded.
processAndWritePrices ctx factories adapterId currentState feedIds currentTime payloadHex = do
  ((newValues, timestamp, rejectedValues), config) <- checkNewValues currentState.feedData feedIds currentTime payloadHex

  if L.null $ newValues then do
    pure currentState
  else do
    newData <- newFeedData ctx factories.pillFactory adapterId currentState.feedData config.currentTimestamp (newValues, timestamp)
    newRewardState <- maybeMakeRewards ctx.caller factories.rewardFactory currentState.rewardState config.currentTimestamp $ length newValues

    pure $ AdapterState with feedData = newData, rewardState = Some newRewardState

-- Private

checkNewValues feedData feedIds currentTime payloadHex = do
  config <- verifyConfigAgainstLedger $ adapter_config_fun feedIds currentTime
  let result = processPayloadNumeric config payloadHex

  pure $ (determineNewValues (config.currentTimestamp, feedData) feedIds result, config)

newFeedData ctx pillFactory adapterId feedData currentTimestamp (newValues, timestamp)  = do
  let newEntries = entriesFromValues currentTimestamp timestamp newValues

  case pillFactory of
    None -> let
      newRecords = createNewRecords newEntries $ map (\(_, _) -> None) newEntries
      newFeedData = M.fromList $ map (\(feedId, record) -> (feedId, [record])) newRecords
      in do
        -- emitting only when no pill factory is passed
        _ <- emitPriceDataEvents (ctx.owner, ctx.updaters) adapterId $ map (\(feedId, record) -> (feedId, record.priceData)) newRecords

        pure $ M.union newFeedData feedData

    Some factory -> do
      newPills <- exercise factory CreatePricePills with
        caller = ctx.caller
        viewers = ctx.viewers
        stalenessMs = pill_staleness_ms
        adapterId
        inputData = newEntries

      length newPills === length newValues

      let newRecords = createNewRecords newEntries $ map Some newPills
      let mergedFeedData = L.foldl addToFeedData feedData newRecords

      let (newItems, toArchive) = partitionRecords currentTimestamp mergedFeedData

      exercise factory ArchivePricePills with caller = ctx.caller, contractIds = map (\record -> fromSome $ record.pillCid) toArchive

      pure $ M.fromList newItems
