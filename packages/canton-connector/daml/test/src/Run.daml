module Run where

import Daml.Script
import Splice.Api.FeaturedAppRightV2
import IRedStoneCore
import IRedStoneAdapter
import Input
import Helpers.FindContract
import Helpers.MockFeatured
import Helpers.Utils
import Helpers.VerifyResults

main : Input -> Script ()
main input = script do
  let updater = input.updater
  let viewer = input.viewer
  let beneficiary = input.beneficiary
  let owner = input.owner
  let dso = input.dso

  currentTime <- getTime
  adapterCid <- findOneAdapter Input.adapterId updater

  appRightCid <- findAnyAppRight beneficiary
  let featuredCid = coerceContractId @FeaturedAppRight @MockFeaturedAppRight appRightCid
  featuredDisclosure <- queryDisclosure @MockFeaturedAppRight beneficiary featuredCid

  values <- submitDisclosed viewer [featuredDisclosure] do
    exerciseCmd (coerceContractId @IRedStoneAdapter @IRedStoneCore adapterCid) GetPrices with
      caller = viewer
      payloadHex = input.payload
      feedIds = input.feedIds
      currentTime
  debug $ "Processed result: " <> show values

  newCid <- submitDisclosed updater [featuredDisclosure] do
    exerciseCmd adapterCid WritePrices with
      caller = updater
      payloadHex = input.payload
      feedIds = input.feedIds
      currentTime
      additionalPillViewers = None

  adapterCid <- findOneAdapter Input.adapterId viewer

  readResult <- submit viewer do
    exerciseCmd adapterCid ReadPriceData with
      caller = viewer
      feedIds = input.feedIds

  verifyWithResult currentTime readResult values

  pure ()
