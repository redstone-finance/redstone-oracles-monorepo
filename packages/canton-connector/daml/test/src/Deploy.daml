module Deploy where

import Daml.Script
import DA.Map as M
import Splice.Api.FeaturedAppRightV2
import IRedStonePricePillFactory
import IRedStoneRewardFactory
import RedStoneCore
import RedStoneCoreClient
import RedStoneAdapter
import RedStonePricePillFactory
import RedStoneRewardFactory
import Input
import Helpers.MockFeatured

main : Input -> Script ()
main input = script do
  let owner = input.owner
  let updater = input.updater
  let viewer = input.viewer
  let client = input.client
  let beneficiary = input.beneficiary
  let dso = input.dso

  featuredCid <- submit (actAs [dso] <> readAs [beneficiary]) do
    createCmd MockFeaturedAppRight with dso, provider = beneficiary

  debug $ "MockFeaturedAppRight " <> show featuredCid

  coreCid <- submit (actAs [owner, beneficiary]) do
    createCmd RedStoneCore with
      viewers = [viewer]
      coreId = Input.adapterId
      owner = owner
      shouldVerifyViewer = True
      beneficiary = Some beneficiary
      featuredCid = Some $ toInterfaceContractId @FeaturedAppRight featuredCid

  debug $ "RedStoneCore " <> show coreCid

  pillFactoryCid <- submit (actAs owner) do
    createCmd RedStonePricePillFactory with
      factoryId = "Factory for " <> Input.adapterId
      owner
      creators = [updater]

  debug $ "RedStonePricePillFactory " <> show pillFactoryCid

  rewardFactoryCid <- submit (actAs [owner, beneficiary]) do
    createCmd RedStoneRewardFactory with
      factoryId = "RewardFactory for " <> Input.adapterId
      owner
      creators = [updater, viewer]
      featuredCid = toInterfaceContractId @FeaturedAppRight featuredCid
      beneficiary

  debug $ "RedStoneRewardFactory " <> show rewardFactoryCid

  adapterCid <- submit owner do
      createCmd RedStoneAdapter with
        adapterId = Input.adapterId
        owner
        updaters = [updater]
        viewers = [viewer]
        feedData = M.empty
        pillFactory = Some $ toInterfaceContractId @IRedStonePricePillFactory pillFactoryCid
        rewardState = None
        rewardFactory = Some $ toInterfaceContractId @IRedStoneRewardFactory rewardFactoryCid

  debug $ "RedStoneAdapter " <> show adapterCid

  coreClientCid <- submit owner do
     createCmd RedStoneCoreClient with
       owner = owner
       viewers = [client]

  debug $ "RedStoneCoreClient " <> show coreClientCid

  return ()
