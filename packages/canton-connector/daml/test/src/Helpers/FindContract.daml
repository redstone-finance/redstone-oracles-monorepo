module Helpers.FindContract (
    findOneAdapter
    , findAnyAdapter
    , findOnePricePill
    , findAnyPricePill
    , findAnyAppRight
) where

import Daml.Script
import DA.Foldable (forA_)
import DA.List as L
import DA.Optional (fromSome)
import Splice.Api.FeaturedAppRightV1
import IRedStoneAdapter
import IRedStonePricePill
import RedStoneTypes

-- Public

findOneAdapter = findAdapter True
findAnyAdapter = findAdapter False

findOnePricePill = findPricePill True
findAnyPricePill = findPricePill False

findAnyAppRight = findAppRight False

-- Private

findContract checkIsUnique test party contracts = do
  let filtered = filter (\(_, view) -> test view) $ map (\(cid, view) -> (cid, fromSome view)) contracts

  forA_ filtered
    $ \ (cid, view)
      -> do debug $ "Contract ID: " <> show cid
            debug $ "Contract data: " <> show view

  assertMsg "No contract found" $ not . null $ contracts
  assertMsg ("Contract length is " <> show (L.length filtered)) $  not checkIsUnique || L.length filtered == 1

  let (contractCid, _) = L.head filtered

  return contractCid

findAdapter: Bool -> Text -> Party ->  Script (ContractId IRedStoneAdapter)
findAdapter checkIsUnique adapterId party = do
    contracts <- queryInterface @IRedStoneAdapter party

    findContract checkIsUnique (\view -> view.adapterId == adapterId) party contracts

findPricePill: Bool -> Text -> RedStoneFeedId -> Party -> Script (ContractId IRedStonePricePill)
findPricePill checkIsUnique adapterId feedId party = do
   contracts <- queryInterface @IRedStonePricePill party

   findContract checkIsUnique (\view -> view.feedId == feedId && view.adapterId == adapterId) party contracts

findAppRight: Bool -> Party -> Script (ContractId FeaturedAppRight)
findAppRight checkIsUnique party = do
   contracts <- queryInterface @FeaturedAppRight party

   findContract checkIsUnique (\view -> view.provider == party) party contracts
