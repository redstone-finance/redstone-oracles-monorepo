module Factory where

import Daml.Script
import DA.Assert
import DA.Map as M
import DA.Optional(fromSome)
import DA.Foldable(forA_)
import Splice.Api.FeaturedAppRightV2
import IRedStonePricePill
import RedStonePricePillFactory
import IRedStonePricePillFactory
import IRedStoneAdapter
import RedStoneAdapter
import Time
import Input
import Helpers.MockFeatured
import Helpers.Utils

main : Input -> Script ()
main input = script do
  dso <- allocateParty "DSO"
  owner <- allocateParty "RedStoneOracleOwner"
  updater <- allocateParty "RedStoneOracleUpdater"
  viewer <- allocateParty "RedStoneOracleViewer"
  beneficiary <- allocateParty "RedStoneBeneficiary"
  client <- allocateParty "Client"

  currentTime <- getTime

  let verifier = verifyResult input.feedIds (beneficiary,dso,viewer)

  featuredCid <- submit (actAs dso <> readAs beneficiary) do
    createCmd MockFeaturedAppRight with dso, provider = beneficiary

  pillFactoryCid <- submit (actAs [owner, beneficiary]) do
    createCmd RedStonePricePillFactory with
      factoryId = "Factory"
      owner
      creators = [updater]
      beneficiary
      featuredCid = toInterfaceContractId @FeaturedAppRight featuredCid

  featuredDisclosure <- queryDisclosure @MockFeaturedAppRight beneficiary featuredCid
  factoryDisclosure <- queryDisclosure @RedStonePricePillFactory updater pillFactoryCid

  adapterCid <- submit (actAs [owner] <> readAs [updater, viewer]) do
    createCmd RedStoneAdapter with
      adapterId = Input.adapterId
      owner
      updaters = [updater]
      viewers = [viewer, client]
      feedData = M.empty
      pillFactory = Some $ toInterfaceContractId @IRedStonePricePillFactory pillFactoryCid

  debug $ "Adapter CID: " <> show adapterCid

  newCid <- submitDisclosed updater [featuredDisclosure, factoryDisclosure] do
    exerciseCmd (toInterfaceContractId @IRedStoneAdapter adapterCid) WritePrices with
      caller = updater
      payloadHex = input.payload
      feedIds = input.feedIds
      currentTime
      additionalPillViewers = Some [client]

  debug $ "New CID: " <> show newCid

  readResult <- submit viewer do
    exerciseCmd newCid ReadPriceData with
      caller = viewer
      feedIds = input.feedIds

  debug $ "Read result Viewer: " <> show readResult

  verifier 1.0 currentTime

  readResult <- submit client do
    exerciseCmd newCid ReadPriceData with
      caller = client
      feedIds = input.feedIds

  debug $ "Read result Client: " <> show readResult

  verifier 1.0 currentTime

verifyResult feedIds (beneficiary,dso,viewer) multiplier currentTime = do
  markers <- queryInterface @FeaturedAppActivityMarker beneficiary
  let weightSum = sum $ map (\(_, view) -> (fromSome view).weight) markers
  let decLength = intToDecimal . length

  weightSum === multiplier * decLength feedIds

  pillEntries <- queryInterface @IRedStonePricePill viewer
  debug pillEntries

  decLength pillEntries === multiplier * decLength feedIds

  let entryMap = M.fromList [ (view.feedId, view) | (_, Some view) <- pillEntries ]

  forA_ feedIds \feedId -> do
    let entry = fromSome $ M.lookup feedId entryMap
    entry.priceData.writeTimestamp === timeToMillis currentTime
