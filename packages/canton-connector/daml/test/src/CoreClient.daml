module CoreClient where

import Daml.Script
import Splice.Api.FeaturedAppRightV2
import IRedStoneCore
import RedStoneCore
import RedStoneCoreClient
import Input
import Helpers.MockFeatured
import Helpers.Utils

main : Input -> Script ()
main input = script do
  dso <- allocateParty "DSO"
  owner <- allocateParty "RedStoneOracleOwner"
  viewer <- allocateParty "RedStoneOracleViewer"
  beneficiary <- allocateParty "RedStoneBeneficiary"
  client <- allocateParty "Client"

  currentTime <- getTime

  featuredCid <- submit dso do
    createCmd MockFeaturedAppRight with dso, provider = owner

  coreCid <- submit (actAs [owner, beneficiary]) do
    createCmd RedStoneCore with
      coreId = "RedStoneCore-123"
      owner
      viewers = [viewer]
      beneficiary = Some beneficiary
      featuredCid = Some $ toInterfaceContractId @FeaturedAppRight featuredCid

  featuredDisclosure <- queryDisclosure @MockFeaturedAppRight owner featuredCid
  coreDisclosure <- queryDisclosure @RedStoneCore owner coreCid

  result <- submitDisclosed viewer [featuredDisclosure] do
    exerciseCmd (toInterfaceContractId @IRedStoneCore coreCid) GetPrices with
      payloadHex = input.payload
      feedIds = input.feedIds
      currentTime
      caller = viewer

  debug $ "Processed result: " <> show result

  coreClientCid <- submit owner do
    createCmd RedStoneCoreClient with
      owner = owner
      viewers = [client]

  currentTime <- getTime

  result <- submitDisclosed client [featuredDisclosure, coreDisclosure] do
    exerciseCmd coreClientCid GetPricesDisclosed with
      payloadHex = input.payload
      feedIds = input.feedIds
      currentTime
      adapterCid = (toInterfaceContractId @IRedStoneCore coreCid)
      caller = client

  debug $ "Client result: " <> show result

  pure ()
