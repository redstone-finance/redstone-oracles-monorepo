module IRedStoneAdapter where

import RedStoneTypes
import WritePricesContext

interface IRedStoneAdapter where
  viewtype RedStoneAdapterView

  iRedStoneAdapter_VerifyViewer : Party -> Update ()
  iRedStoneAdapter_VerifyUpdater : Party -> Update ()
  iRedStoneAdapter_WritePricesImpl : Party -> (ContractId IRedStoneAdapter) -> [RedStoneFeedId] -> Time -> PayloadHex -> Optional WritePricesContext -> Update (ContractId IRedStoneAdapter)
  iRedStoneAdapter_ReadPriceDataImpl : [RedStoneFeedId] -> Update [Optional (RedStonePriceData RedStoneValue)]
  iRedStoneAdapter_ReadPricesImpl : [RedStoneFeedId] -> Update [RedStoneValue]
  iRedStoneAdapter_GetUniqueSignerThresholdImpl: () -> Update Int

  nonconsuming choice WritePrices : ContractId IRedStoneAdapter
    with
      caller : Party
      feedIds : [RedStoneFeedId]
      currentTime : Time
      payloadHex : PayloadHex
      context : Optional WritePricesContext
    controller caller
    do
      iRedStoneAdapter_VerifyUpdater this caller
        >> iRedStoneAdapter_WritePricesImpl this caller self feedIds currentTime payloadHex context

  nonconsuming choice ReadPrices : [RedStoneValue]
    with
      caller : Party
      feedIds : [RedStoneFeedId]
    controller caller
    do
      iRedStoneAdapter_VerifyViewer this caller
        >> iRedStoneAdapter_ReadPricesImpl this feedIds

  nonconsuming choice ReadPriceData : [Optional (RedStonePriceData RedStoneValue)]
    with
      caller : Party
      feedIds : [RedStoneFeedId]
    controller caller
    do
      iRedStoneAdapter_VerifyViewer this caller
        >> iRedStoneAdapter_ReadPriceDataImpl this feedIds

  nonconsuming choice GetUniqueSignerThreshold : Int
    with
      caller : Party
    controller caller
    do
      iRedStoneAdapter_VerifyViewer this caller
        >> iRedStoneAdapter_GetUniqueSignerThresholdImpl this ()

data RedStoneAdapterView = RedStoneAdapterView
  with
    adapterId : Text
  deriving (Eq, Show, Ord)
