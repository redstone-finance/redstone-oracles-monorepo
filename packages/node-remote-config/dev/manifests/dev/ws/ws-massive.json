{
  "interval": 1000,
  "priceAggregator": "median",
  "defaultSource": [
    "coingecko"
  ],
  "defaultBroadcasters": [
    "redstone-packages",
    "influx",
    "s3"
  ],
  "sourceTimeout": 8000,
  "deviationCheck": {
    "deviationWithRecentValues": {
      "maxPercent": 25,
      "maxDelayMilliseconds": 120000
    }
  },
  "tokens": {
    "TSLA": {
      "source": [],
      "deviationCheck": {
        "deviationWithRecentValues": {
          "maxPercent": 30,
          "maxDelayMilliseconds": 120000
        }
      },
      "broadcasters": [
        "influx",
        "s3"
      ],
      "denomination": "USD",
      "rateFeed": false
    }
  }
}
