{
  "interval": 10000,
  "priceAggregator": "median",
  "defaultSource": ["kraken-usd"],
  "defaultBroadcasters": ["redstone-packages", "influx"],
  "sourceTimeout": 7000,
  "minValidSourcesPercentage": 1,
  "deviationCheck": {
    "deviationWithRecentValues": {
      "maxPercent": 30,
      "maxDelayMilliseconds": 120000
    }
  },
  "tokens": {
    "TON": {
      "source": [
        "binance-usdc",
        "binance-usdt",
        "bitget-eur",
        "bitget-usdt",
        "bitmart-usdt",
        "bitrue-usdc",
        "bitrue-usdt",
        "bitstamp-usd",
        "bybit-usdc",
        "bybit-usdt",
        "gate-usdt",
        "htx-usdt",
        "kraken-eur",
        "kraken-usd",
        "kucoin-usdt",
        "lbank-usdt",
        "mexc-usdc",
        "mexc-usdt",
        "okx-usdt",
        "xt-usdt"
      ]
    },
    "USDT": {},
    "EUR": {},
    "USDC": {}
  }
}
