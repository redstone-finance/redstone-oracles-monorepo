{
  "interval": 10000,
  "priceAggregator": "median",
  "defaultSource": [],
  "sourceTimeout": 7000,
  "minValidSourcesPercentage": 1,
  "deviationCheck": {
    "deviationWithRecentValues": {
      "maxPercent": 30,
      "maxDelayMilliseconds": 120000
    }
  },
  "tokens": {
    "WBTC/BTC": {
      "source": ["non-usd-based"],
      "denomination": "BTC",
      "rateFeed": false
    },
    "WBTC": {
      "source": ["kraken-usd"],
      "denomination": "USD",
      "rateFeed": false
    },
    "BTC": {
      "source": ["kraken-usd"],
      "denomination": "USD",
      "rateFeed": false
    }
  }
}
