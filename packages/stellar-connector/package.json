{
  "name": "@redstone-finance/stellar-connector",
  "version": "0.9.0",
  "description": "A tool to inject RedStone data into Stellar compatible smart contracts",
  "main": "dist/src/index.js",
  "exports": "./dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "license": "MIT",
  "scripts": {
    "clean": "yarn global:ts-clean",
    "build": "yarn global:tsc -p tsconfig.build.json",
    "build:turbo": "yarn global:turbo build",
    "typecheck": "yarn global:tsc --noEmit",
    "typecheck:turbo": "yarn global:turbo typecheck",
    "build-dependent:turbo": "yarn build:turbo --filter=...@redstone-finance/stellar-connector",
    "lint": "yarn global:eslint .",
    "lint:fix": "yarn global:eslint --fix .",
    "test": "make build && yarn global:jest:cov --runInBand",
    "preversion": "yarn build",
    "pack-package": "yarn build && cd dist && npm pack",
    "convert-keys": "yarn global:tsx scripts/convert-keys.ts",
    "sample-run": "yarn build:turbo && node dist/scripts/sample-run.js",
    "sample-deploy": "yarn global:tsx scripts/sample-deploy.ts",
    "deploy-sep-40": "yarn global:tsx scripts/deploy-sep-40.ts",
    "check-sep-40": "yarn build:turbo && node dist/scripts/check-sep-40.js",
    "sample-upgrade": "yarn global:tsx scripts/sample-upgrade.ts",
    "sample-upgrade-tx": "yarn global:tsx scripts/ledger/sample-upgrade-tx.ts",
    "deploy-multicall": "yarn global:tsx scripts/deploy-multicall.ts",
    "get-ledger-data": "yarn global:tsx ./scripts/ledger/get-ledger-data.ts",
    "create-multisig": "yarn global:tsx ./scripts/ledger/create-multisig.ts",
    "change-owner": "yarn global:tsx scripts/change-owner.ts",
    "accept-ownership": "yarn global:tsx scripts/accept-ownership.ts",
    "accept-ownership-tx": "yarn global:tsx scripts/ledger/accept-ownership-tx.ts",
    "cancel-ownership-transfer": "yarn global:tsx scripts/cancel-ownership-transfer.ts",
    "cancel-ownership-transfer-tx": "yarn global:tsx scripts/ledger/cancel-ownership-transfer-tx.ts",
    "change-owner-tx": "yarn global:tsx scripts/ledger/change-owner-tx.ts",
    "sign-tx": "yarn global:tsx ./scripts/ledger/sign-tx.ts",
    "combine-signatures": "yarn global:tsx ./scripts/ledger/combine-signatures.ts",
    "create-account": "yarn global:tsx ./scripts/create-account-with-funds.ts",
    "get-stellar-address": "yarn global:tsx ./scripts/get-stellar-address.ts",
    "instantiate-price-feed": "CONTRACT_NAME=redstone_price_feed yarn global:tsx scripts/instantiate-price-feed.ts",
    "extend-instance-ttl": "yarn global:tsx scripts/extend-instance-ttl.ts",
    "sep-40-add-feeds-tx": "yarn global:tsx scripts/ledger/sep-40/add-feeds-tx.ts",
    "sep-40-remove-feeds-tx": "yarn global:tsx scripts/ledger/sep-40/remove-feeds-tx.ts",
    "sep-40-update-feeds-tx": "yarn global:tsx scripts/ledger/sep-40/update-feeds-tx.ts",
    "sep-40-replace-feed-id-tx": "yarn global:tsx scripts/ledger/sep-40/replace-feed-id-tx.ts",
    "sep-40-set-resolution-tx": "yarn global:tsx scripts/ledger/sep-40/set-resolution-tx.ts",
    "extend-sep-40-ttl": "yarn global:tsx scripts/extend-sep-40-ttl.ts"
  },
  "dependencies": {
    "@creit-tech/stellar-router-sdk": "npm:@jsr/creit-tech__stellar-router-sdk@^0.2.0",
    "@ethersproject/bytes": "^5.6.1",
    "@redstone-finance/multichain-kit": "workspace:*",
    "@redstone-finance/protocol": "workspace:*",
    "@redstone-finance/sdk": "workspace:*",
    "@redstone-finance/utils": "workspace:*",
    "@stellar/stellar-sdk": "^14.6.1",
    "axios": "^1.15.2",
    "lodash": "^4.17.23",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@ledgerhq/hw-app-str": "^7.7.1",
    "@ledgerhq/hw-transport-node-hid-singleton": "^6.35.1",
    "@redstone-finance/chain-agnostic-oracle-tests": "workspace:*",
    "@redstone-finance/chain-configs": "workspace:*",
    "@redstone-finance/mars-rover": "git+https://github.com/redstone-finance/mars-rover.git#v0.0.4",
    "@types/urijs": "^1.19.25",
    "dotenv": "^16.0.3"
  },
  "files": [
    "src",
    "dist/src/**/*"
  ],
  "publishConfig": {
    "access": "public"
  }
}
