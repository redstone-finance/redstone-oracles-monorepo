{
  "interval": 10000,
  "priceAggregator": "median",
  "defaultSource": ["coingecko"],
  "sourceTimeout": 7000,
  "minValidSourcesPercentage": 1,
  "deviationCheck": {
    "deviationWithRecentValues": {
      "maxPercent": 30,
      "maxDelayMilliseconds": 300000
    }
  },
  "tokens": {
    "LAB.m": {
      "source": ["aperture-swap-manta-weth-500"],
      "denomination": "USD",
      "rateFeed": false
    },
    "ETH": {
      "source": [
        "binance-usdt",
        "bingx-usdt",
        "bitfinex-usd",
        "bitget-usdt",
        "bitmart-usdt",
        "bitrue-usdt",
        "bitstamp-usd",
        "coinbase-usd",
        "gate-usdt",
        "kaiko-v2",
        "kraken-usd",
        "kucoin-usdt",
        "lbank-usdt",
        "okx-usdt",
        "xt"
      ],
      "skipBroadcasting": true,
      "denomination": "USD",
      "rateFeed": false
    },
    "USDT": {
      "source": [
        "bitstamp-usd",
        "coinbase-usd",
        "coingecko",
        "coinmarketcap",
        "gate-usd",
        "kaiko-v2",
        "kraken-usd"
      ],
      "deviationCheck": {
        "deviationWithRecentValues": {
          "maxPercent": 5,
          "maxDelayMilliseconds": 300000
        }
      },
      "skipBroadcasting": true,
      "denomination": "USD",
      "rateFeed": false
    }
  }
}
