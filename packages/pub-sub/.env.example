# start here https://eu-west-1.console.aws.amazon.com/iot/home?region=eu-west-1#/thinghub

MQTT_CERT="-----BEGIN CERTIFICATE-----

-----END CERTIFICATE-----"

MQTT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----

-----END RSA PRIVATE KEY-----"

# check here: https://eu-west-1.console.aws.amazon.com/systems-manager/parameters/%252Fdev%252Fmqtt%252Fendpoint/description?region=eu-west-1&tab=Table
MQTT_ENDPOINT=real-iot-endpoint.eu-west-1.amazonaws.com

# e.g. 'data-package/redstone-primary-demo/USDT/#, "#" subscribes to all messages
MQTT_TOPIC="#"

# NATS NKey authentication
# Supports plain and TLS connections
# Start a local NATS broker: docker compose -f nats/docker-compose.yml up -d
NATS_NKEY_SEED=SUAJDWCHASKBHPIMHPKZ7XEOAGLIINEYK5YSVXTIF5Z6772QWVTQ6ANBCQ
NATS_INTEGRATION_HOST=localhost:4222

# Optional TLS: set NATS_CA_CERT_ENV to the name of the env var holding the PEM CA cert.
# e.g. NATS_CA_CERT_ENV=NATS_CA_CERT and NATS_CA_CERT=$(cat nats/certs/ca.crt)
# NATS_CA_CERT_ENV=NATS_CA_CERT
