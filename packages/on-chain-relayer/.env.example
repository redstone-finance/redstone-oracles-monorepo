RELAYER_ITERATION_INTERVAL=5000
RPC_URLS=["https://goerli.blockpi.network/v1/rpc/public"]
PRIVATE_KEY=
GAS_LIMIT=5000000
HEALTHCHECK_PING_URL=https://your-uptime-kuma-url.com/api/push/wxyz7890?status=up&msg=OK
EXPECTED_TX_DELIVERY_TIME_IN_MS=500
MANIFEST_FILE=./relayer-manifests-multi-feed/relayerManifest.json
HISTORICAL_PACKAGES_GATEWAYS=["https://d1zm8lxy9v2ddd.cloudfront.net"]
HISTORICAL_PACKAGES_DATA_SERVICE_ID=redstone-primary-prod
CACHE_SERVICE_URLS=

# AUTHENTICATED_GATEWAYS=[{"url":"https://oracle-gateway.a.redstone.finance","apiKeyEnvPath":"AUTH_GATEWAY_API_KEY"}]
# AUTH_GATEWAY_API_KEY=

# when >0, runs the trigger functions depending on the manifest in the fallback mode
FALLBACK_OFFSET_IN_MILLISECONDS=0

# when set to true, checks all conditions even if a dependent update condition succeeds
IS_NOT_LAZY=false

# when set to url - will try to deliver tx by calling fastlane api first, url: https://bsc.atlas-operations-relay.fastlane.xyz
OEV_AUCTION_URL=
OEV_RESOLVE_AUCTION_TIMEOUT_MS=2000
OEV_TOTAL_TIMEOUT_MS=10000

#pubsub
RUN_WITH_PUB_SUB=false
PUB_SUB_ENDPOINT=
PUB_SUB_MINIMAL_OFFCHAIN_SIGNERS_COUNT=3
PUB_SUB_WAIT_FOR_OTHER_SIGNERS_MS=500
PUB_SUB_UPDATE_SUBSCRIPTION_INTERVAL_MS=120000

# NATS pub-sub connection. Each secret is referenced by PUB_SUB_CONFIGS via its env-var name.
PUB_SUB_CONFIGS=[{"caCertEnvPath":"NATS_CA_CERT","clientCertEnvPath":"NATS_CLIENT_CERT","clientKeyEnvPath":"NATS_CLIENT_KEY","host":"tls://ec2-108-128-195-153.eu-west-1.compute.amazonaws.com:5431","nkeySeedEnvPath":"NATS_NKEY_SEED","type":"nats"}]

# Each referenced secret takes precedence over its <NAME>_SSM_PATH companion. The SSM path points to
# an SSM parameter and is queried only when the plain env var is unset and pub-sub is enabled
# (RUN_WITH_PUB_SUB=true).
NATS_CLIENT_CERT="-----BEGIN CERTIFICATE-----

-----END CERTIFICATE-----" # value from SSM -> /dev/nats/tls/client-cert
NATS_CLIENT_CERT_SSM_PATH=/dev/nats/tls/client-cert
NATS_CA_CERT="-----BEGIN CERTIFICATE-----

-----END CERTIFICATE-----" # value from SSM -> /dev/nats/tls/ca-cert
NATS_CA_CERT_SSM_PATH=/dev/nats/tls/ca-cert
NATS_CLIENT_KEY="-----BEGIN PRIVATE KEY-----

-----END PRIVATE KEY-----" # value from SSM -> /dev/nats/tls/client-key
NATS_CLIENT_KEY_SSM_PATH=/dev/nats/tls/client-key
NATS_NKEY_SEED="SUXYZXYZXYZXYZ" # value from SSM -> /dev/nats/reader-seed-nkey
NATS_NKEY_SEED_SSM_PATH=/dev/nats/reader-seed-nkey

HEALTHCHECK_ENABLED=true
