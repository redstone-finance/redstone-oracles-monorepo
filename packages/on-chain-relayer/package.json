{
  "name": "@redstone-finance/on-chain-relayer",
  "version": "0.9.0",
  "types": "dist/src/index.d.ts",
  "main": "dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js",
    "./src/run-relayer": {
      "types": "./dist/src/run-relayer",
      "default": "./dist/src/run-relayer.js"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": " yarn global:tsc -p tsconfig.build.json",
    "build:turbo": "yarn global:turbo build",
    "typecheck": "yarn global:tsc --noEmit",
    "typecheck:turbo": "yarn global:turbo typecheck",
    "clean": "yarn global:ts-clean",
    "bundle": "ENTRYPOINT=src/main-remote-config.ts yarn global:rollup -c ../../rollup.config.mjs && OUTPUT=dist/relayer-worker.js ENTRYPOINT=src/main.ts yarn global:rollup -c ../../rollup.config.mjs",
    "start": "node dist/src/main.js",
    "start:bundled": "node dist/index.js",
    "start:remote": "node dist/src/main-remote-config.js",
    "start:dev": "yarn global:tsx src/main.ts",
    "start:debug": "yarn build:turbo && yarn start",
    "start:dev:remote": "yarn build && yarn global:tsx src/main-remote-config.ts",
    "run-manual-script": "yarn global:tsx scripts/master-manual-script/index.ts",
    "lint": "yarn global:eslint .",
    "lint:fix": "yarn global:eslint --fix .",
    "run-script": "yarn global:tsx",
    "test": "NODE_ENV=test mocha --ignore 'test/relayer-manifests/**' --ignore 'test/data-processing-strategy/**' 'test/**/*test.ts'",
    "test:chain-config-presence": "NODE_ENV=test mocha test/relayer-manifests/chain-config-presence.test.ts",
    "test:price-feed-validation": "NODE_ENV=test RUN_NONDETERMINISTIC_TESTS=t mocha test/relayer-manifests/price-feed-validation.test.ts",
    "test:manifests-validation": "NODE_ENV=test mocha test/relayer-manifests/manifests-validation.test.ts",
    "test:data-processing-strategy": "NODE_ENV=test mocha 'test/data-processing-strategy/*test.ts'",
    "test:write-prices": "NODE_ENV=test mocha test/relayer/run-iteration.test.ts",
    "preversion": "yarn build"
  },
  "dependencies": {
    "@ethersproject/units": "^5.7.0",
    "@redstone-finance/chain-configs": "workspace:*",
    "@redstone-finance/chain-orchestrator": "workspace:*",
    "@redstone-finance/healthcheck": "workspace:*",
    "@redstone-finance/internal-utils": "workspace:*",
    "@redstone-finance/multichain-kit": "workspace:*",
    "@redstone-finance/on-chain-relayer-common": "workspace:*",
    "@redstone-finance/protocol": "workspace:*",
    "@redstone-finance/pub-sub": "workspace:*",
    "@redstone-finance/remote-config": "workspace:*",
    "@redstone-finance/sdk": "workspace:*",
    "@redstone-finance/utils": "workspace:*",
    "cron-parser": "^4.8.1",
    "dotenv": "^16.0.3",
    "lodash": "^4.17.23",
    "toad-scheduler": "^3.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@ethersproject/strings": "^5.7.0",
    "@types/chai": "^4.3.4",
    "@types/lodash": "^4.14.195",
    "@types/sinon-chai": "^3.2.12",
    "chai": "^4.3.10",
    "chai-as-promised": "^7.1.1",
    "mocha": "^11",
    "msw": "^2.4.10",
    "sinon": "^18.0.0"
  },
  "overrides": {
    "elliptic": "^6.6.1"
  },
  "resolutions": {
    "elliptic": "^6.6.1"
  },
  "files": [
    "src",
    "dist",
    "contracts"
  ],
  "publishConfig": {
    "access": "public"
  }
}
